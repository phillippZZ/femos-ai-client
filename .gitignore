/class
**/__pycache__/
.env
# 1. Ignore the contents of the skills folder
/skills/*

# 2. But DO NOT ignore these specific files
!/skills/cmd.py
!/skills/skill_creator.py
!/skills/skill_reader.py
.DS_Store

# 3. Ignore all workspace content but keep directory structure
/workspace/*
!/workspace/tasks/
!/workspace/indexes/
/workspace/tasks/*
!/workspace/tasks/.gitkeep
/workspace/indexes/*
!/workspace/indexes/.gitkeep